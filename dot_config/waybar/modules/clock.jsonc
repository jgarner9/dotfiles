{
  "clock": {
    "timezone": "America/Denver",
    "format": "󰃱 <span size='11pt'> {:%H:%M | %B %d, %Y}</span>",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "on-scroll": 1,
    },
    "actions": {
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
      "on-click-right": "mode",
    },
  },
}
