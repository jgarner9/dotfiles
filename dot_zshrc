# source plugins
if [[ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
	source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi
if [[ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
	source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# MR JASON'S SUPER AWESOME ALIASES
alias ls="ls --color -F"
alias spm="sudo pacman"
alias cat="bat"

# add autocompletion
autoload -Uz compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' rehash true
compinit

# customize prompt
autoload -U colors && colors
autoload -U vcs_info

setopt PROMPT_SUBST
zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git:*' formats 'on %F{magenta}git:%F{cyan}(%b)%f%c%u'
zstyle ':vcs_info:git:*' actionformats 'on %F{magenta}git:%F{cyan}(%b|%a)%f%c%u'

precmd() {
	# Get git info
	vcs_info
}

PROMPT='%F{cyan}%n%f@%F{blue}%m%f in %F{yellow}%~%f ${vcs_info_msg_0_}
'
PROMPT+='%(?.%F{green}.%F{red})❯%f '

if [[ -f $HOME/.local/bin/env ]]; then
	. "$HOME/.local/bin/env"
fi
. "$HOME/.zprofile"

# exit the shell when zellij exits, so closing zellij closes the window
# (pairs with on_force_close "quit" in the zellij config)
export ZELLIJ_AUTO_EXIT=true
eval "$(zellij setup --generate-auto-start zsh)"

eval "$(zoxide init --cmd cd zsh)"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
